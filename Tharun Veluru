      <div class="skill-bar-group">
        <div class="skill-bar-item">
          <div class="skill-bar-top"><span>SQL / BigQuery</span><span>95%</span></div>
          <div class="skill-bar-track"><div class="skill-bar-fill" style="width:95%"></div></div>
        </div>
        <div class="skill-bar-item">
          <div class="skill-bar-top"><span>Power BI / DAX</span><span>90%</span></div>
          <div class="skill-bar-track"><div class="skill-bar-fill" style="width:90%;animation-delay:0.2s"></div></div>
        </div>
        <div class="skill-bar-item">
          <div class="skill-bar-top"><span>Python (Pandas)</span><span>82%</span></div>
          <div class="skill-bar-track"><div class="skill-bar-fill" style="width:82%;animation-delay:0.4s"></div></div>
