    </div>
    <div class="hero-stats fade-up fade-up-d5">
      <div class="stat-item">
        <div class="stat-num">2+</div>
        <div class="stat-label">Years Exp.</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">25+</div>
        <div class="stat-label">Dashboards Built</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">1M+</div>
        <div class="stat-label">Rows Analyzed</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">30%</div>
        <div class="stat-label">Error Reduction</div>
      </div>
    </div>
  </div>

  <div class="hero-right">
